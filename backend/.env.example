# Snovio API Configuration
# Get your API key from: https://app.snov.io/api-setting

# Option 1: Use API Key (Recommended - simpler)
SNOVIO_API_KEY=your_api_key_here

# Option 2: Use OAuth credentials (Alternative)
# SNOVIO_CLIENT_ID=your_client_id
# SNOVIO_CLIENT_SECRET=your_client_secret

# Instructions:
# 1. Copy this file to .env
# 2. Add your Snovio API key
# 3. Restart the backend server
