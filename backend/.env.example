# ── Required ──────────────────────────────────────────────────────────────────
# Generate a strong random string: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string

# ── Optional paid email providers ─────────────────────────────────────────────
# Users can store their own keys via the /api/keys endpoint.
# Keys below are server-level defaults.

# Hunter.io  https://hunter.io/api-documentation
HUNTER_API_KEY=

# ZeroBounce  https://www.zerobounce.net/docs/
ZEROBOUNCE_API_KEY=

# NeverBounce  https://developers.neverbounce.com/
NEVERBOUNCE_API_KEY=

# Apollo.io  https://apolloio.github.io/apollo-api-docs/
APOLLO_API_KEY=

# Clearbit  https://dashboard.clearbit.com/docs
CLEARBIT_API_KEY=

# Snov.io  https://snov.io/api
SNOVIO_CLIENT_ID=
SNOVIO_CLIENT_SECRET=

# Legacy single key (still supported)
# SNOVIO_API_KEY=your_api_key_here
