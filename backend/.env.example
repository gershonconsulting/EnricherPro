# EnricherPro v5.0 — Environment Configuration Template
# Copy this file to .env and fill in your API keys
# cp .env.example .env && nano .env

# ── Email Finder Providers (waterfall order: 1 → 6) ──────────────────────────

# 1. Hunter.io — best domain pattern detection
# Get key: https://hunter.io/api-keys (free tier: 50 searches/mo)
HUNTER_API_KEY=your_hunter_api_key_here

# 2. Prospeo
# Get key: https://prospeo.io (~$0.01/email)
PROSPEO_API_KEY=your_prospeo_api_key_here

# 3. Anymailfinder
# Get key: https://anymailfinder.com ($49/1,000 verified)
ANYMAILFINDER_API_KEY=your_anymailfinder_api_key_here

# 4. Apollo — generous free tier
# Get key: https://developer.apollo.io
APOLLO_API_KEY=your_apollo_api_key_here

# 5. Dropcontact
# Get key: https://app.dropcontact.com (~$0.065/email)
DROPCONTACT_API_KEY=your_dropcontact_api_key_here

# 6. Snov.io — last resort (use existing credentials from v4.x)
# Get keys: https://app.snov.io/api-setting
SNOVIO_CLIENT_ID=your_snovio_client_id_here
SNOVIO_CLIENT_SECRET=your_snovio_client_secret_here

# ── Email Validation Services ─────────────────────────────────────────────────

# ZeroBounce — catch-all resolution + AI scoring
# Get key: https://zerobounce.net/members/apikey (free tier: 100 credits/mo)
ZEROBOUNCE_API_KEY=your_zerobounce_api_key_here

# NeverBounce — alternative AI validator
# Get key: https://app.neverbounce.com ($0.008/email)
NEVERBOUNCE_API_KEY=your_neverbounce_api_key_here

# ── Server Configuration ──────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=5000

# ── SMTP Verification (Layer 5) ───────────────────────────────────────────────
ENABLE_SMTP_CHECK=true
SMTP_TIMEOUT_SECONDS=10

# ── Instructions ─────────────────────────────────────────────────────────────
# 1. Copy this file:  cp .env.example .env
# 2. Fill in the keys above (minimum: HUNTER_API_KEY + ZEROBOUNCE_API_KEY)
# 3. Install deps:    pip install -r requirements_v5.txt
# 4. Start server:    uvicorn api_server_v5:app --host 0.0.0.0 --port 5000
# 5. Verify:          curl http://localhost:5000/api/health
